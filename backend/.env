# =============================================================================
# Backend (Django) – copy to .env and fill values. In production set env/secrets
# on Render (or your host); do not commit .env with real secrets.
# =============================================================================

# Django (required)
DEBUG=True
SECRET_KEY=change-me-to-a-secret-key

# Database – for local dev, SQLite (db.sqlite3 in backend/) is used by default.
# Omit DATABASE_URL to use SQLite. For production (Render/Railway), set DATABASE_URL.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_ENGINE=django.db.backends.sqlite3
# DB_NAME defaults to backend/db.sqlite3 when unset
# PostgreSQL (only when DB_ENGINE=django.db.backends.postgresql):
# DB_NAME=lottery_db
# DB_USER=lottery_user
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# Stripe – use test keys (pk_test_*, sk_test_*, whsec_*) in dev; set live keys in production only; never commit real keys
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=usd

# Razorpay (India: UPI, cards, netbanking, wallets)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_CURRENCY=INR

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@localhost

# SendGrid / Mailgun (optional)
SENDGRID_API_KEY=
USE_SENDGRID=False
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
USE_MAILGUN=False

# Redis (optional for local dev)
# Leave REDIS_URL empty to use in-memory cache, channels, and eager Celery.
# Set it to use a real Redis instance (e.g. redis://localhost:6379/0).
REDIS_URL=

# S3 / DigitalOcean Spaces (optional)
USE_S3_STORAGE=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=nyc3
AWS_S3_CUSTOM_DOMAIN=

# Security (set True in production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Sentry (optional – set in production for error tracking)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=production

# Optional
ALLOWED_HOSTS=localhost,127.0.0.1
SESSION_COOKIE_AGE=86400
RATELIMIT_ENABLE=True
CSRF_TRUSTED_ORIGINS=
